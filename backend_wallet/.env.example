APP_NAME="Wallet System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-render-backend.onrender.com
FRONTEND_URL=https://your-vercel-project.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=aws.connect.psdb.cloud
DB_PORT=3306
DB_DATABASE=wallet_system
DB_USERNAME=
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
RUN_MIGRATIONS=false
RUN_ADMIN_SEEDER=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ERTITECH_PAYOUT_BASE_URL=https://api.ertipay.com/uat
ERTITECH_PAYOUT_USERNAME=
ERTITECH_PAYOUT_PASSWORD=
ERTITECH_PAYOUT_MERCHANT_ID=
ERTITECH_PAYOUT_WALLET_ID=
ERTITECH_PAYOUT_AES_KEY=
ERTITECH_PAYOUT_PREFERRED_BANK=pnb
ERTITECH_PAYOUT_MODE=live

# Pusher Configuration (for WebSocket)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_key
PUSHER_APP_SECRET=your_pusher_secret
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"


RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_MODE=live

RETAILER_RECHARGE_PROVIDER=
RETAILER_RECHARGE_BASE_URL=
RETAILER_RECHARGE_API_KEY=
RETAILER_RECHARGE_SECRET_KEY=
RETAILER_RECHARGE_AUTH_BASE_URL=
RETAILER_RECHARGE_GRANT_TYPE=client_credentials
RETAILER_RECHARGE_SCOPE=
RETAILER_RECHARGE_AGENT_ID=
RETAILER_RECHARGE_USERNAME=
RETAILER_RECHARGE_PASSWORD=
RETAILER_RECHARGE_MODE=live
